# ─────────────────────────────────────────────────────────────────
# Cloud Cost Management Dashboard — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── AWS Credentials ──────────────────────────────────────────────
# Create a read-only IAM user in your AWS console.
# Required permissions: ReadOnlyAccess (or a custom policy with
# ec2:Describe*, s3:List*, rds:Describe*, lambda:List*, cloudwatch:GetMetricStatistics)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# ── PostgreSQL Database ──────────────────────────────────────────
# Used by Docker Compose to create the database.
POSTGRES_USER=ccm_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=cloud_cost_db
DATABASE_URL=postgresql://ccm_user:change_me_strong_password@db:5432/cloud_cost_db

# ── Application Settings ─────────────────────────────────────────
# Set to "true" to use simulated demo data instead of real AWS.
# Useful for testing the UI without AWS credentials.
DEMO_MODE=false

# How often to collect AWS data (in hours). Default: 6
COLLECTION_INTERVAL_HOURS=6

# Secret key for API (generate a random 32-char string)
SECRET_KEY=replace_with_a_random_secret_key_32chars

# ── Frontend ─────────────────────────────────────────────────────
# URL the React frontend uses to reach the backend
VITE_API_BASE_URL=http://localhost:8000
